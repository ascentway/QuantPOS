# ============================================================
# QuantPOS Environment Variables — TEMPLATE
# ============================================================
# This file is committed to Git as a reference template.
# DO NOT put real values here.
# ─────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. Never commit .env to Git (already in .gitignore)
# ============================================================


# ─────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────
DB_USER=
DB_USERNAME=
DB_PASSWORD=
DB_URL=jdbc:postgresql://localhost:5432/quantpos
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/quantpos


# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379


# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_DAYS=7


# ─────────────────────────────────────────────────────────────
# Brevo SMTP (Email)
# ─────────────────────────────────────────────────────────────
BREVO_EMAIL=
BREVO_SMTP_KEY=
BREVO_SENDER_NAME=QuantPOS
BREVO_SENDER_EMAIL=


# ─────────────────────────────────────────────────────────────
# Stripe (Billing)
# ─────────────────────────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────
# OpenAI / LangChain4j (AI Agent)
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=


# ─────────────────────────────────────────────────────────────
# Application Config
# ─────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
SPRING_PROFILES_ACTIVE=dev


# ─────────────────────────────────────────────────────────────
# Grafana (Monitoring)
# ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

